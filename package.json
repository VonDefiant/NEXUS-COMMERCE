{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx prisma db push --accept-data-loss && tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:onpremise": "npm run build && node scripts/build-onpremise.js && npx pkg dist-onpremise/server.bin.js -t node18-win-x64,node18-linux-x64 --out-path dist-onpremise/exe",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-onpremise",
    "lint": "tsc --noEmit",
    "start": "npx prisma db push --accept-data-loss && node dist/server.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.49.0",
    "@sentry/react": "^10.49.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-auth": "^1.6.5",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "i18next": "^26.0.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
