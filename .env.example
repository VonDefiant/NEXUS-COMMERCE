# DATABASE_URL: Cadena de conexión para PostgreSQL (Neon.tech / Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_db?schema=public"

# BETTER_AUTH_SECRET: Llave criptográfica secreta para firmar sesiones (Generar con: openssl rand -base64 32)
BETTER_AUTH_SECRET="cambiar-en-produccion"

# VITE_SENTRY_DSN_FRONTEND: Llave de Sentry para el FRONTEND (React - Monitoreo del Navegador)
VITE_SENTRY_DSN_FRONTEND=""

# SENTRY_DSN_BACKEND: Llave de Sentry para el BACKEND (Node.js - Monitoreo del Servidor)
SENTRY_DSN_BACKEND=""

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- TELEMETRÍA ---
# Solo necesario en On-Premise si quieres apuntar a tu Nube. 
# En la Nube SaaS recibe los pings validando con esta clave.
NEXUS_CLOUD_URL=
NEXUS_TELEMETRY_SECRET="REEMPLAZAR-CON-SECRET-SEGURO-MINIMO-32-CHARS"

# 'on-premise' | 'railway' (Para saber de dónde viene el ping)
HOSTING_TYPE="on-premise"

# RESEND_API_KEY: Llave de la API de Resend para enviar correos (Opcional, usado para recuperación de contraseña)
RESEND_API_KEY=""

# EMAIL_FROM_ADDRESS: Dirección de correo para los envíos (Ej. soporte@tudominio.com)
EMAIL_FROM_ADDRESS=""

# NEXUS_LICENSE_SECRET: Debe ser IDÉNTICO al NEXUS_LICENSE_SECRET del Master Hub.
# NUNCA compartas este valor. Solicítalo al administrador del Master Hub.
NEXUS_LICENSE_SECRET=
